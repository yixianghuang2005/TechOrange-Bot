# ── LINE Bot ──────────────────────────────────────────────
LINE_CHANNEL_SECRET=your_line_channel_secret
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token

# ── Dialogflow ────────────────────────────────────────────
DIALOGFLOW_PROJECT_ID=your_gcp_project_id
# 把 GCP Service Account JSON 內容貼在這（或用檔案路徑）
GOOGLE_APPLICATION_CREDENTIALS=service-account.json

# ── Firebase ──────────────────────────────────────────────
# 把 Firebase Service Account JSON 內容貼在這（或用檔案路徑）
FIREBASE_CREDENTIALS=firebase-service-account.json

# ── Gemini ────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key

# ── TechOrange RSS（不需要 key）────────────────────────────
RSS_MAIN=https://techorange.com/feed/
RSS_SECURITY=https://techorange.com/category/cybersecurity/feed/
